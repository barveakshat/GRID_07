{
  "info": {
    "_postman_id": "8f353154-a90d-47b1-9f20-4da67784d8e8",
    "name": "GRID_07 API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "create post",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorType\": \"USER\",\n  \"authorId\": {{userId}},\n  \"content\": \"Post created from Postman\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/posts",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "posts"
          ]
        }
      }
    },
    {
      "name": "add comment to post",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"authorType\": \"USER\",\n  \"authorId\": {{userId}},\n  \"parentCommentId\": null,\n  \"content\": \"First comment from Postman\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/posts/{{postId}}/comments",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "posts",
            "{{postId}}",
            "comments"
          ]
        }
      }
    },
    {
      "name": "like post",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": {{likeUserId}}\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/posts/{{postId}}/like",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "posts",
            "{{postId}}",
            "like"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "userId",
      "value": "1"
    },
    {
      "key": "likeUserId",
      "value": "2"
    },
    {
      "key": "postId",
      "value": "1"
    }
  ]
}

